{
  "manifest_version": 3,
  "name": "Todoist Quick Capture",
  "version": "1.0.0",
  "description": "Instantly capture the current page to Todoist Inbox.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["https://api.todoist.com/api/*"],
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Capture to Todoist"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+T"
      },
      "description": "Capture current tab to Todoist Inbox"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "todoist-quick-capture@alberto",
      "strict_min_version": "109.0"
    }
  }
}
